{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "AssetArcade",
  "description": "Agent-native asset discovery, structured metadata, and integration guidance",
  "colors": {
    "primary": "#8B5CF6",
    "light": "#A78BFA",
    "dark": "#7C3AED"
  },
  "logo": {
  "light": "/logo/light.svg",
  "dark": "/logo/dark.svg",
  "href": "https://assetarcade.mintlify.app/"
  },
  "favicon": {
    "light": "/favicon.svg",
    "dark": "/favicon.svg"
  },
  "appearance": {
    "default": "dark",
    "strict": false
  },
  "background": {
    "decoration": "gradient",
    "color": {
      "light": "#F8F7FA",
      "dark": "#0B0E14"
    }
  },
  "styling": {
    "eyebrows": "section",
    "codeblocks": "dark"
  },
  "navigation": {
    "groups": [
      {
        "group": "Overview",
        "pages": [
          "index",
          "overview",
          "quickstart",
          "authentication",
          "deprecation-policy"
        ]
      },
      {
        "group": "Reference",
        "openapi": "openapi/v1.json"
      }
    ]
  }
}
