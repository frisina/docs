// ---------------------------------------------------------------------------
// OpenAPI V1 Spec Generator
// ---------------------------------------------------------------------------
//
// Registers all V1 endpoints and their Zod schemas in an OpenAPI 3.1 registry,
// then exports a function to generate the full document.
//
// Server base: /api  (path items use /v1/... so resolved URLs = /api/v1/...)
// ---------------------------------------------------------------------------

import { z } from 'zod';
import {
  OpenAPIRegistry,
  OpenApiGeneratorV31,
} from '@asteasolutions/zod-to-openapi';

import { ErrorResponseSchema } from './schemas/common';
import { SearchQueryInputSchema, SearchResponseSchema } from './schemas/search';
import {
  AssetDetailSchema,
  AssetManifestResponseSchema,
  AssetMarkdownMetadataResponseSchema,
} from './schemas/asset';
import { CapabilitiesResponseSchema } from './schemas/capabilities';
import { PublisherProfileSchema } from './schemas/publishers';
import {
  BranchListResponseSchema,
  VersionListResponseSchema,
  EntitlementResponseSchema,
} from './schemas/branches';

// ---- Registry -------------------------------------------------------------

const registry = new OpenAPIRegistry();

// ---- Reusable param schemas -----------------------------------------------

const AssetIdParamSchema = z.object({
  assetId: z.string().openapi({ description: 'Asset ID', example: 'abc123' }),
});

const PublisherSlugParamSchema = z.object({
  slug: z.string().openapi({ description: 'Publisher slug', example: 'acme-games' }),
});

const BranchIdParamSchema = z.object({
  assetId: z.string().openapi({ description: 'Asset ID', example: 'abc123' }),
  branchId: z.string().openapi({ description: 'Branch ID', example: 'br_xyz' }),
});

const BranchQuerySchema = z.object({
  branch: z
    .string()
    .optional()
    .openapi({
      description: "Branch ID to scope metadata. Defaults to the asset's default branch.",
    }),
});

// ---- Error helper ---------------------------------------------------------

function errorContent() {
  return {
    'application/json': {
      schema: ErrorResponseSchema,
    },
  };
}

// ---- Endpoints ------------------------------------------------------------

// POST /v1/agent/search
registry.registerPath({
  method: 'post',
  path: '/v1/agent/search',
  tags: ['Search'],
  summary: 'Capability-based agent asset search',
  description:
    'Search for assets by capability requirements with scoring, engine constraints, and pricing filters. Returns lightweight results with deep-link URLs for focused metadata endpoints.',
  request: {
    body: {
      content: {
        'application/json': {
          schema: SearchQueryInputSchema,
        },
      },
      required: true,
    },
  },
  responses: {
    200: {
      description: 'Search results sorted by fit score',
      content: {
        'application/json': {
          schema: SearchResponseSchema,
        },
      },
    },
    400: {
      description: 'Validation error',
      content: errorContent(),
    },
    500: {
      description: 'Internal server error',
      content: errorContent(),
    },
  },
});

// GET /v1/assets/{assetId}
registry.registerPath({
  method: 'get',
  path: '/v1/assets/{assetId}',
  tags: ['Assets'],
  summary: 'Full asset detail',
  description:
    'Returns the full asset detail including storefront listing, pricing, branch-resolved technical metadata, manifest, context, integration notes, version history, and file listing.',
  request: {
    params: AssetIdParamSchema,
    query: BranchQuerySchema,
  },
  responses: {
    200: {
      description: 'Asset detail',
      content: {
        'application/json': {
          schema: AssetDetailSchema,
        },
      },
    },
    404: {
      description: 'Asset not found or branch invalid',
      content: errorContent(),
    },
    500: {
      description: 'Internal server error',
      content: errorContent(),
    },
  },
});

// GET /v1/assets/{assetId}/manifest
registry.registerPath({
  method: 'get',
  path: '/v1/assets/{assetId}/manifest',
  tags: ['Assets'],
  summary: 'Focused manifest endpoint',
  description:
    'Returns the validated GameMaker manifest and agent readiness level. Returns null manifest for invalid or legacy JSON.',
  request: {
    params: AssetIdParamSchema,
    query: BranchQuerySchema,
  },
  responses: {
    200: {
      description: 'Manifest response',
      content: {
        'application/json': {
          schema: AssetManifestResponseSchema,
        },
      },
    },
    404: {
      description: 'Asset not found',
      content: errorContent(),
    },
    500: {
      description: 'Internal server error',
      content: errorContent(),
    },
  },
});

// GET /v1/assets/{assetId}/context
registry.registerPath({
  method: 'get',
  path: '/v1/assets/{assetId}/context',
  tags: ['Assets'],
  summary: 'Focused context metadata',
  description:
    'Returns the raw context markdown and an AI-generated summary for the asset.',
  request: {
    params: AssetIdParamSchema,
    query: BranchQuerySchema,
  },
  responses: {
    200: {
      description: 'Context metadata',
      content: {
        'application/json': {
          schema: AssetMarkdownMetadataResponseSchema,
        },
      },
    },
    404: {
      description: 'Asset not found',
      content: errorContent(),
    },
    500: {
      description: 'Internal server error',
      content: errorContent(),
    },
  },
});

// GET /v1/assets/{assetId}/integration
registry.registerPath({
  method: 'get',
  path: '/v1/assets/{assetId}/integration',
  tags: ['Assets'],
  summary: 'Focused integration metadata',
  description:
    'Returns the raw integration markdown and an AI-generated summary for the asset.',
  request: {
    params: AssetIdParamSchema,
    query: BranchQuerySchema,
  },
  responses: {
    200: {
      description: 'Integration metadata',
      content: {
        'application/json': {
          schema: AssetMarkdownMetadataResponseSchema,
        },
      },
    },
    404: {
      description: 'Asset not found',
      content: errorContent(),
    },
    500: {
      description: 'Internal server error',
      content: errorContent(),
    },
  },
});

// ---- Phase 2 endpoints ----------------------------------------------------

// GET /v1/capabilities
registry.registerPath({
  method: 'get',
  path: '/v1/capabilities',
  tags: ['Capabilities'],
  summary: 'Capability taxonomy',
  description:
    'Returns all active capabilities grouped by category. Capabilities are stable slugs used for agent search filtering.',
  responses: {
    200: {
      description: 'Capabilities grouped by category',
      content: {
        'application/json': {
          schema: CapabilitiesResponseSchema,
        },
      },
    },
    500: {
      description: 'Internal server error',
      content: errorContent(),
    },
  },
});

// GET /v1/assets/{assetId}/branches
registry.registerPath({
  method: 'get',
  path: '/v1/assets/{assetId}/branches',
  tags: ['Assets'],
  summary: 'List public branches',
  description:
    'Returns active and deprecated branches that have a published content version. Only lists branches that the detail endpoint will accept via ?branch= parameter.',
  request: {
    params: AssetIdParamSchema,
  },
  responses: {
    200: {
      description: 'Branch listing',
      content: {
        'application/json': {
          schema: BranchListResponseSchema,
        },
      },
    },
    404: {
      description: 'Asset not found',
      content: errorContent(),
    },
    500: {
      description: 'Internal server error',
      content: errorContent(),
    },
  },
});

// GET /v1/assets/{assetId}/branches/{branchId}/versions
registry.registerPath({
  method: 'get',
  path: '/v1/assets/{assetId}/branches/{branchId}/versions',
  tags: ['Assets'],
  summary: 'Branch version history',
  description:
    'Returns the file version history for a branch, including file counts and sizes per version.',
  request: {
    params: BranchIdParamSchema,
  },
  responses: {
    200: {
      description: 'Version history',
      content: {
        'application/json': {
          schema: VersionListResponseSchema,
        },
      },
    },
    404: {
      description: 'Asset or branch not found',
      content: errorContent(),
    },
    500: {
      description: 'Internal server error',
      content: errorContent(),
    },
  },
});

// Security scheme for authenticated endpoints
registry.registerComponent('securitySchemes', 'clerkAuth', {
  type: 'http',
  scheme: 'bearer',
  description: 'Clerk JWT session token',
});

// GET /v1/assets/{assetId}/entitlement
registry.registerPath({
  method: 'get',
  path: '/v1/assets/{assetId}/entitlement',
  tags: ['Library'],
  summary: 'Check asset entitlement',
  description:
    'Check if the authenticated user owns this asset. Requires a Clerk JWT session token. Returns 404 for missing/unpublished assets, 401 if not authenticated.',
  security: [{ clerkAuth: [] }],
  request: {
    params: AssetIdParamSchema,
  },
  responses: {
    200: {
      description: 'Entitlement status',
      content: {
        'application/json': {
          schema: EntitlementResponseSchema,
        },
      },
    },
    401: {
      description: 'Authentication required',
      content: errorContent(),
    },
    404: {
      description: 'Asset not found',
      content: errorContent(),
    },
    500: {
      description: 'Internal server error',
      content: errorContent(),
    },
  },
});

// GET /v1/publishers/{slug}
registry.registerPath({
  method: 'get',
  path: '/v1/publishers/{slug}',
  tags: ['Publishers'],
  summary: 'Public publisher profile',
  description:
    'Returns the public profile of a publisher by slug. The verified field indicates verification status, matching the pattern used in asset detail responses.',
  request: {
    params: PublisherSlugParamSchema,
  },
  responses: {
    200: {
      description: 'Publisher profile',
      content: {
        'application/json': {
          schema: PublisherProfileSchema,
        },
      },
    },
    404: {
      description: 'Publisher not found',
      content: errorContent(),
    },
    500: {
      description: 'Internal server error',
      content: errorContent(),
    },
  },
});

// ---- Document generator ---------------------------------------------------

export function generateOpenApiDocument() {
  const generator = new OpenApiGeneratorV31(registry.definitions);

  const doc = generator.generateDocument({
    openapi: '3.1.0',
    info: {
      title: 'AssetArcade API',
      version: '1.0.0',
      description:
        'Agent-native asset marketplace API. Provides capability-based asset discovery, structured manifests, compatibility metadata, and integration guidance for AI agents and developer tooling.',
    },
    servers: [
      {
        url: '/api',
        description: 'Relative base path (resolves to /api/v1/... in production)',
      },
    ],
    tags: [
      { name: 'Search', description: 'Agent-driven asset discovery' },
      { name: 'Assets', description: 'Asset detail and sub-resources' },
      { name: 'Capabilities', description: 'Capability taxonomy for asset classification' },
      { name: 'Library', description: 'User library and entitlements' },
      { name: 'Publishers', description: 'Publisher profiles' },
    ],
  });

  // Add deprecation policy extension (not supported by zod-to-openapi directly)
  (doc.info as unknown as Record<string, unknown>)['x-deprecation-policy'] = {
    versioningScheme: 'path-prefix',
    currentVersion: 'v1',
    status: 'active',
    sunsetDate: null,
    minimumDeprecationPeriod: '6 months',
    deprecationSignals: ['Deprecation header', 'Sunset header', 'deprecated: true in spec'],
    policyUrl: 'https://assetarcade.mintlify.app/deprecation-policy',
  };

  return doc;
}
