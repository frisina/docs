{
  "openapi": "3.1.0",
  "info": {
    "title": "AssetArcade API",
    "version": "1.0.0",
    "description": "Structured asset discovery and metadata API for modern game development workflows. Search by capability, inspect manifests and integration guidance, resolve branches and versions, and retrieve publisher and entitlement data for developer-led, AI-assisted tooling.",
    "x-deprecation-policy": {
      "versioningScheme": "path-prefix",
      "currentVersion": "v1",
      "status": "active",
      "sunsetDate": null,
      "minimumDeprecationPeriod": "6 months",
      "deprecationSignals": [
        "Deprecation header",
        "Sunset header",
        "deprecated: true in spec"
      ],
      "policyUrl": "https://assetarcade.mintlify.app/deprecation-policy"
    }
  },
  "servers": [
    {
      "url": "/api",
      "description": "Relative base path (resolves to /api/v1/... in production)"
    }
  ],
  "tags": [
    {
      "name": "Search",
      "description": "Agent-driven asset discovery"
    },
    {
      "name": "Assets",
      "description": "Asset detail and sub-resources"
    },
    {
      "name": "Capabilities",
      "description": "Capability taxonomy for asset classification"
    },
    {
      "name": "Library",
      "description": "User library and entitlements"
    },
    {
      "name": "Publishers",
      "description": "Publisher profiles"
    }
  ],
  "components": {
    "securitySchemes": {
      "clerkAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Clerk JWT session token"
      }
    },
    "schemas": {
      "SearchResponse": {
        "type": "object",
        "properties": {
          "query": {
            "$ref": "#/components/schemas/SearchQueryEcho"
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AgentSearchResult"
            }
          }
        },
        "required": [
          "query",
          "results"
        ]
      },
      "SearchQueryEcho": {
        "type": "object",
        "properties": {
          "capabilities": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "engine": {
            "type": [
              "string",
              "null"
            ]
          },
          "engineVersion": {
            "type": [
              "string",
              "null"
            ]
          },
          "constraints": {
            "type": "object",
            "properties": {
              "maxPriceCents": {
                "type": [
                  "number",
                  "null"
                ]
              },
              "licenseType": {
                "type": "string",
                "enum": [
                  "personal",
                  "professional"
                ]
              },
              "minReadinessLevel": {
                "type": [
                  "number",
                  "null"
                ]
              }
            },
            "required": [
              "maxPriceCents",
              "licenseType",
              "minReadinessLevel"
            ]
          },
          "limit": {
            "type": "number"
          }
        },
        "required": [
          "capabilities",
          "engine",
          "engineVersion",
          "constraints",
          "limit"
        ]
      },
      "AgentSearchResult": {
        "type": "object",
        "properties": {
          "assetId": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "shortDescription": {
            "type": [
              "string",
              "null"
            ]
          },
          "fitScore": {
            "type": "number"
          },
          "pricing": {
            "type": "object",
            "properties": {
              "effectivePriceCents": {
                "type": "number"
              },
              "licenseType": {
                "type": "string",
                "enum": [
                  "personal",
                  "professional"
