      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Human-readable error (backward compat)"
          },
          "errorDetail": {
            "$ref": "#/components/schemas/ErrorDetail"
          }
        },
        "required": [
          "error"
        ]
      },
      "ErrorDetail": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "enum": [
              "VALIDATION_ERROR",
              "NOT_FOUND",
              "UNAUTHORIZED",
              "RATE_LIMITED",
              "INTERNAL_ERROR"
            ]
          },
          "message": {
            "type": "string"
          },
          "details": {
            "type": "object",
            "properties": {
              "field": {
                "type": "string"
              },
              "reason": {
                "type": "string"
              }
            }
          }
        },
        "required": [
          "code",
          "message"
        ],
        "description": "Structured error with machine-parseable code. Prefer this over error."
      },
      "SearchQuery": {
        "type": "object",
        "properties": {
          "capabilities": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "description": "Non-empty array of capability slugs. Whitespace-only entries are stripped; request fails if no non-empty entries remain."
          },
          "engine": {
            "type": "string",
            "description": "Engine filter (e.g., \"GameMaker\")."
          },
          "engineVersion": {
            "type": "string",
            "description": "Engine version constraint (e.g., \"2024.8\"). Requires engine to be set. Must be a parseable dotted numeric version."
          },
          "constraints": {
            "type": "object",
            "properties": {
              "maxPriceCents": {
                "type": "number",
                "minimum": 0
              },
              "licenseType": {
                "type": "string",
                "enum": [
                  "personal",
                  "professional"
                ]
              },
              "minReadinessLevel": {
                "type": "number",
                "minimum": 0,
                "maximum": 3
              }
            }
          },
          "limit": {
            "type": "number",
            "description": "Max results. Defaults to 10. Clamped to 1-25 range (floored if fractional)."
          }
        },
        "required": [
          "capabilities"
        ]
      },
