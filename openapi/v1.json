          },
          "bestBranch": {
            "$ref": "#/components/schemas/SearchBranchSummary"
          },
          "explanation": {
            "$ref": "#/components/schemas/SearchExplanation"
          },
          "assetApiUrl": {
            "type": "string"
          },
          "detailUrls": {
            "$ref": "#/components/schemas/DetailUrls"
          }
        },
        "required": [
          "assetId",
          "slug",
          "title",
          "shortDescription",
          "fitScore",
          "pricing",
          "bestBranch",
          "explanation",
          "assetApiUrl",
          "detailUrls"
        ]
      },
